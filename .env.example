# Environment Variables for Production Deployment
# Copy this file to .env and fill in your production values
# NEVER commit .env to git!

# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Cache: default is file-based (.django_cache/) so scanner heartbeat is shared across Gunicorn/uWSGI workers.
# If the guard display stays on "Waiting" while the dashboard shows Scanner ACTIVE, do NOT set USE_LOCMEM_CACHE=1.
# USE_LOCMEM_CACHE=1

# Public HTTPS tunnel (ngrok): NGROK_HTTPS_COOKIES=1 marks session/csrf cookies Secure and trusts X-Forwarded-Proto.
# Plain http:// local/LAN: use 0 (defaults in code were insecure cookies; IDE/OS may still export =1 unless .env overrides — settings use load_dotenv(override=True)).
NGROK_HTTPS_COOKIES=0
# NGROK_HTTPS_COOKIES=1
# Behind nginx/IIS without ngrok — trust forwarded scheme (do not use on raw runserver unless the proxy sets it):
# TRUST_X_FORWARDED_PROTO=1
# Extra comma-separated origins for CSRF (e.g. http://10.0.0.5:8000): DJANGO_CSRF_TRUSTED_ORIGINS=http://10.0.0.5:8000
# Optional: append your tunnel URL to CSRF trusted origins (also set in code); NGROK_HOST may be set by your ngrok wrapper
# NGROK_HOST=your-subdomain.ngrok-free.dev

# Database
# DB_ENGINE: sqlite (default) | mysql | postgresql
# For SQLite: leave DB_ENGINE unset or set DB_ENGINE=sqlite (no other DB_* needed).
# For MySQL: set DB_ENGINE=mysql and the MySQL variables below.
# For PostgreSQL: set DB_ENGINE=postgresql and the PostgreSQL variables below.
# DB_ENGINE=sqlite

# MySQL (e.g. XAMPP)
# DB_ENGINE=mysql
# DB_NAME=gate_analytics
# DB_USER=root
# DB_PASSWORD=your-mysql-password
# DB_HOST=127.0.0.1
# DB_PORT=3306

# PostgreSQL
# DB_ENGINE=postgresql
# DB_NAME=gate_analytics_db
# DB_USER=event_user
# DB_PASSWORD=your-secure-password
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Email (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# AWS S3 Storage (Optional, if using cloud storage)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# Mapbox (Optional, for location features)

# --- Gate guard wall + incident reports (do these one at a time) ---
# Guard scan-success popup layout: split (photo|text), poster (banner photo + details), idcard (card panel)
# GATE_GUARD_STUDENT_POPUP_STYLE=split
# Minimum seconds between daily gate scans (student QR). Default 30. Legacy: GATE_SCAN_REPEAT_COOLDOWN_MINUTES (whole minutes).
# GATE_SCAN_REPEAT_COOLDOWN_SECONDS=30
# GATE_SCAN_REPEAT_COOLDOWN_MINUTES=5
# global (default) = wait after any IN/OUT before the next scan. same_direction = only block repeat IN or repeat OUT (allows quick IN then OUT).
# GATE_SCAN_REPEAT_COOLDOWN_SCOPE=global
# 1) Shared secret for /gate/guard-display/ and /gate/embed-scanner/ (required for guard monitor)
# GATE_GUARD_DISPLAY_TOKEN=your-long-random-token
#
# 2) Optional: Django Group names (comma-separated, case-insensitive) for who gets in-app + email alerts
#    Create matching groups in Admin → Groups and add staff users (not students).
# GATE_GUARD_INCIDENT_GROUPS_SAS=Student Affairs,SAS
# GATE_GUARD_INCIDENT_GROUPS_REGISTRAR=Registrar
#
# 3) Optional: extra email addresses (comma-separated) if offices are not in Django yet
# GATE_GUARD_INCIDENT_EMAILS_SAS=sas@school.edu
# GATE_GUARD_INCIDENT_EMAILS_REGISTRAR=registrar@school.edu
#
# 4) Fallback: if no user matches the groups above, broadcast to all staff in-app (true/false)
# GATE_GUARD_INCIDENT_FALLBACK_BROADCAST=true
#
# 5) General alert inbox (comma-separated) — used when no office emails are configured
# NOTIFICATION_EMAILS=admin@school.edu

